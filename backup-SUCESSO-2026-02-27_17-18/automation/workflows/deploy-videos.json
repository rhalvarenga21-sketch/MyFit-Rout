{
  "name": "deploy-videos",
  "description": "Workflow automatizado para deployment de vídeos de exercícios",
  "version": "1.0.0",
  "created": "2026-02-27",
  "steps": [
    {
      "id": 1,
      "name": "Verificar Status",
      "description": "Verifica status atual: quantos exercícios e vídeos temos",
      "type": "command",
      "command": "node automation/scripts/merge_videos.cjs --status",
      "onError": "abort",
      "expectedOutput": "exercícios encontrados"
    },
    {
      "id": 2,
      "name": "Executar Merge de Vídeos",
      "description": "Executa script para adicionar vídeos aos exercícios",
      "type": "script",
      "script": "automation/scripts/merge_videos.cjs",
      "timeout": 60000,
      "onError": "abort",
      "expectedOutput": "vídeos adicionados"
    },
    {
      "id": 3,
      "name": "Gerar Lista Atualizada",
      "description": "Gera lista atualizada com todos os exercícios e vídeos",
      "type": "script",
      "script": "automation/scripts/gerar_lista_atualizada.cjs",
      "timeout": 30000,
      "onError": "continue",
      "output": "data/exercises.ts"
    },
    {
      "id": 4,
      "name": "Git Add",
      "description": "Adiciona arquivo atualizado ao staging",
      "type": "git",
      "command": "add data/exercises.ts",
      "onError": "abort"
    },
    {
      "id": 5,
      "name": "Git Commit",
      "description": "Faz commit com mensagem descritiva",
      "type": "git",
      "command": "commit -m \"feat: adicionar vídeos automaticamente\"",
      "onError": "abort"
    },
    {
      "id": 6,
      "name": "Git Push",
      "description": "Envia alterações para repositório remoto",
      "type": "git",
      "command": "push",
      "branch": "main",
      "timeout": 120000,
      "onError": "abort"
    },
    {
      "id": 7,
      "name": "Notificar Conclusão",
      "description": "Notifica sucesso do deployment",
      "type": "notification",
      "level": "success",
      "message": "Deploy completo! 78 vídeos ativos",
      "channel": "console",
      "timestamp": true
    }
  ],
  "config": {
    "workingDirectory": "c:\\Users\\C5388757\\Documents\\MyFit-Rout",
    "timeout": 300000,
    "retryOnFailure": false,
    "logFile": "automation/logs/deploy-videos.log",
    "environment": {
      "NODE_ENV": "production",
      "LOG_LEVEL": "info"
    }
  },
  "rollback": {
    "enabled": true,
    "steps": [
      {
        "order": 1,
        "action": "git reset HEAD~1"
      },
      {
        "order": 2,
        "action": "git checkout data/exercises.ts"
      }
    ]
  }
}
