{
    "rewrites": [
        {
            "source": "/",
            "destination": "/index.html"
        },
        {
            "source": "/app",
            "destination": "/app.html"
        },
        {
            "source": "/app/(.*)",
            "destination": "/app.html"
        },
        {
            "source": "/api/(.*)",
            "destination": "/api/$1"
        }
    ],
    "crons": [
        {
            "path": "/api/keep-alive",
            "schedule": "0 8 */5 * *"
        }
    ]
}